{
  "name": "testcafe-reporter-smtp",
  "version": "0.1.0",
  "description": "TestCafe SMTP reporter plugin.",
  "repository": {
    "type": "git",
    "url": "git@github.com:neekfenwick/testcafe-reporter-smtp.git"
  },
  "author": {
    "name": "Nick Fenwick",
    "email": "neek@nickfenwick.com",
    "url": "https://github.com/neekfenwick"
  },
  "main": "lib/index",
  "files": [
    "lib"
  ],
  "scripts": {
    "clean": "rm -rf lib",
    "lint": "eslint src/**/*.js test/**/*.js",
    "build": "npm run clean && cp -r src lib",
    "test": "npm run lint && npm run build && TESTCAFE_SMTP_SMTPHOST=unit-test-mock mocha test/test.js --ui bdd --reporter spec --timeout 20000",
    "preview": "npm run build && node -e \"const plugin=require('testcafe').embeddingUtils.buildReporterPlugin(require('./lib')); require('./test/utils/reporter-test-calls').forEach(call=>plugin[call.method].apply(plugin,call.args)); process.exit(0);\"",
    "publish-please": "publish-please",
    "prepublish": "publish-please guard"
  },
  "keywords": [
    "testcafe",
    "reporter",
    "plugin"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.29.7",
    "callsite-record": "^3.2.2",
    "del": "^7.1.0",
    "eslint": "^8.57.1",
    "mocha": "^10.8.2",
    "normalize-newline": "^1.0.2",
    "publish-please": "^5.5.2",
    "read-file-relative": "^1.2.0",
    "testcafe": "^3.7.5"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "path": "^0.12.7",
    "dotenv": "^16.6.1",
    "handlebars": "^4.7.9",
    "nodemailer": "^9.0.1"
  }
}
